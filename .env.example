# PyAgent Environment Configuration
# Copy this file to .env and fill in your values

# === LLM API Keys ===
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
ZHIPU_API_KEY=xxx.xxx
DEEPSEEK_API_KEY=sk-xxx

# === OpenAI Compatible APIs ===
OPENAI_BASE_URL=https://api.openai.com/v1

# === ZhipuAI Configuration ===
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# === DeepSeek Configuration ===
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# === Model Selection ===
# Options: openai, anthropic, zhipu, deepseek
DEFAULT_LLM_PROVIDER=zhipu

# === Strong Model (Planning) ===
STRONG_MODEL_PROVIDER=zhipu
STRONG_MODEL_NAME=glm-4-plus

# === Balanced Model (Regular Tasks) ===
BALANCED_MODEL_PROVIDER=deepseek
BALANCED_MODEL_NAME=deepseek-chat

# === Fast Model (Memory Processing) ===
FAST_MODEL_PROVIDER=zhipu
FAST_MODEL_NAME=qwen3.5-35b

# === Tiny Model (Intent Detection) ===
TINY_MODEL_PROVIDER=zhipu
TINY_MODEL_NAME=qwen3.5-4b

# === Server Configuration ===
HOST=0.0.0.0
PORT=8000
DEBUG=false

# === Database Configuration ===
DATABASE_URL=sqlite:///data/pyagent.db
DATABASE_POOL_SIZE=5

# === Logging Configuration ===
LOG_LEVEL=INFO
LOG_FILE=logs/pyagent.log

# === Security Configuration ===
SECRET_KEY=your-secret-key-here
API_KEY_HEADER=X-API-Key

# === Memory System ===
MEMORY_ENABLED=true
MEMORY_MAX_TOKENS=4000
MEMORY_EMBEDDING_MODEL=text-embedding-3-small

# === MCP Configuration ===
MCP_ENABLED=true
MCP_SERVERS_DIR=mcps

# === Rate Limiting ===
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
